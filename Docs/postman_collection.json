{
  "info": {
    "name": "Chat IA Backend",
    "description": "Collection for testing the Chat IA Backend API. Auto-saves JWT token on login.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080/api"
    },
    {
      "key": "authToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    pm.test('User registered successfully', () => {",
                  "        pm.response.to.have.status(201);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\",\n  \"email\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('authToken', 'Bearer ' + jsonData.token);",
                  "    pm.test('Token saved to collection variables', () => {",
                  "        pm.expect(jsonData.token).to.not.be.empty;",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"123456\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Sessions",
      "item": [
        {
          "name": "GET /chat/sessions",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions"]
            }
          },
          "response": []
        },
        {
          "name": "POST /chat/sessions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('sessionId', jsonData.id);",
                  "    pm.test('Session ID saved: ' + jsonData.id, () => {});",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My First Chat\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/sessions",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Messages",
      "item": [
        {
          "name": "POST /chat/messages",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chatSessionId\": \"{{sessionId}}\",\n  \"content\": \"Olá, como você está?\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/chat/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "messages"]
            }
          },
          "response": []
        },
        {
          "name": "GET /chat/sessions/{sessionId}/messages",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/sessions/{{sessionId}}/messages",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "sessions", "{{sessionId}}", "messages"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Files",
      "item": [
        {
          "name": "POST /chat/files (upload)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    pm.collectionVariables.set('fileId', jsonData.fileId);",
                  "    pm.test('File ID saved: ' + jsonData.fileId, () => {});",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/chat/files",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "files"]
            }
          },
          "response": []
        },
        {
          "name": "GET /chat/files/{fileId} (download)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "{{authToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/chat/files/{{fileId}}",
              "host": ["{{baseUrl}}"],
              "path": ["chat", "files", "{{fileId}}"]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
